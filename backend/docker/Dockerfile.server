# syntax=docker/dockerfile:1
FROM golang:1.21-alpine AS builder
WORKDIR /src
COPY go.mod ./
RUN go mod download || true
COPY . .
RUN go mod tidy && CGO_ENABLED=0 go build -o /out/toj-server ./cmd/server

FROM alpine:3.20
RUN adduser -D -u 10001 toj
WORKDIR /app
COPY --from=builder /out/toj-server /app/toj-server
COPY config.yaml /app/config.yaml
USER toj
EXPOSE 8080
ENTRYPOINT ["/app/toj-server", "-config", "/app/config.yaml"]
